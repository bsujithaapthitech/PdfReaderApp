<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient">

    <!-- MAIN CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🔹 TOP BAR -->
            <com.google.android.material.appbar.MaterialToolbar
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:minHeight="56dp"
                android:layout_marginTop="24dp"
                android:background="@android:color/white"
                app:titleTextColor="#0F172A"
                app:title="IntelliSummarize"
                app:titleTextAppearance="@style/ToolbarTitle"
                app:titleCentered="true"/>

            <!-- 🔹 FEATURE BAND -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#4F46E5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- ICON -->
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="10dp"/>

                    <!-- TEXT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI-Powered Summaries"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02"
                            android:textColor="@android:color/white"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get instant insights and ask questions from any PDF"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"
                            android:textColor="@android:color/white"/>
                    </LinearLayout>

                    <!-- ACTION -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Try"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_try_button"
                        android:textColor="#4F46E5"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            <!-- 🔹 GREETING -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning 👋"
                android:textSize="23sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginTop="16dp"/>

            <!-- 🔹 HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent PDFs"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textSize="14sp"
                    android:textColor="#4F46E5"/>
            </LinearLayout>

            <!-- 🔹 PDF CARD -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No PDFs yet 📄\nTap + to add one"
                android:textAlignment="center"
                android:textColor="#6B7280"
                android:layout_marginTop="40dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 🔥 FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add PDF"
        app:backgroundTint="#4F46E5"
        app:elevation="8dp"
        android:tint="@android:color/white"
        android:layout_gravity="bottom|end"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>